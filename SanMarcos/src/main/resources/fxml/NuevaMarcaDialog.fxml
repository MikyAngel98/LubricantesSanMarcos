<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Separator?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Vista.controllers.NuevaMarcaDialogController"
      spacing="15" style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-border-radius: 10; -fx-background-radius: 10;"
      prefWidth="400" prefHeight="180">

    <Label text="➕ NUEVA MARCA"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a5276;"/>

    <Separator/>

    <Label text="NOMBRE DE LA MARCA:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <TextField fx:id="txtNombreMarca" promptText="Ej: Castrol, Mobil, Bosch..."
               style="-fx-pref-height: 35; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 5;"/>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button fx:id="btnGuardarMarca" text="GUARDAR"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button fx:id="btnCancelarMarca" text="CANCELAR"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>