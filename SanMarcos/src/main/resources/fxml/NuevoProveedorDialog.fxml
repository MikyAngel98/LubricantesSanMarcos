<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Vista.controllers.NuevoProveedorDialogController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: #f8f9fa;" prefWidth="400" prefHeight="350">

    <Label text="➕ NUEVO PROVEEDOR" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Separator/>

    <Label text="DATOS DE LA EMPRESA:" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
    <TextField fx:id="txtEmpresa" promptText="Nombre de la empresa"/>

    <Label text="DATOS DE CONTACTO:" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
    <TextField fx:id="txtNombre" promptText="Nombre completo"/>
    <TextField fx:id="txtCelular" promptText="Número de celular"/>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button fx:id="btnGuardar" text="GUARDAR" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button fx:id="btnCancelar" text="CANCELAR" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>