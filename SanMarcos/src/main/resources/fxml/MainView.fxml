<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Vista.controllers.MainController"
            stylesheets="@../css/main.css">

    <!-- TOP: Header -->
    <top>
        <VBox>
            <Label text="LUBRICANTES SAN MARCOS" styleClass="header" alignment="CENTER" maxWidth="Infinity"/>
            <Separator/>
        </VBox>
    </top>

    <!-- LEFT: Menú lateral -->
    <left>
        <VBox spacing="8" styleClass="menu-lateral" prefWidth="260">
            <Button text="📦 INVENTARIO - PRODUCTOS" styleClass="btn-menu" onAction="#abrirInventario"/>
            <Button text="🛢️ ACEITES" styleClass="btn-menu" onAction="#abrirAceites"/>
            <Button text="🔧 FILTROS" styleClass="btn-menu" onAction="#abrirFiltros"/>
            <Button text="💡 FOCOS" onAction="#abrirFocos" styleClass="btn-menu"/>

            <Separator styleClass="separator"/>

            <Button text="🛒 VENTAS" styleClass="btn-menu" onAction="#abrirVentas"/>
            <Button text="📥 COMPRAS" styleClass="btn-menu" onAction="#abrirCompras"/>

            <Separator styleClass="separator"/>

            <Button text="➕ NUEVO PRODUCTO" styleClass="btn-success" onAction="#abrirNuevoProducto"/>

            <Separator styleClass="separator"/>

            <Button text="📊 REPORTES" styleClass="btn-menu" onAction="#abrirReportes"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="⚙️ CONFIGURACIÓN" styleClass="btn-config" onAction="#abrirConfiguracion"/>
        </VBox>
    </left>

    <!-- CENTER: StackPane dinámico -->
    <center>
        <StackPane fx:id="panelCentral" styleClass="panel-central">
            <Label text="Seleccione una opción del menú lateral" styleClass="bienvenida"/>
        </StackPane>
    </center>

    <!-- BOTTOM: Footer -->
    <bottom>
        <HBox styleClass="footer">
            <Label text="👤 Usuario: Administrador" styleClass="footer-texto"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblFecha" styleClass="footer-fecha"/>
        </HBox>
    </bottom>

</BorderPane>